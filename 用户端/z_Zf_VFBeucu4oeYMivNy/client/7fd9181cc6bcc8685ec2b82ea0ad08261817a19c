    if (!url) return '';
    return `![${alt}](${url})`
  };

  let out = '';
  el.childNodes?.forEach?.((child) => {
    out += serializeDomToMarkdown(child)
  });

  const isBlock = tag === 'DIV' || tag === 'P' || tag === 'LI' || tag === 'BLOCKQUOTE' || /^H[1-6]$/.test(tag);
  if (isBlock && out && !out.endsWith('\n')) out += '\n';
  return out
};

